rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Colección de usuarios del sistema (login propio, sin Firebase Auth)
    match /systemUsers/{userId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if false;
    }

    // Colección de asistencias / registros del gimnasio
    match /asistencias/{docId} {
      allow read, write: if true;
    }

    // Cualquier otra colección
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
